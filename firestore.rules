rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - email: string (required) - User email
    //   - displayName: string (required) - User display name
    //   - points: number (required) - Total points earned
    //   - level: number (required) - Current level reached
    //   - unlockedLevels: list (required) - List of unlocked levels
    //   - rank: string (required) - User rank (worm, eagle, tiger, lion, dragon)
    //   - bonusPoints: number (optional) - Total bonus points earned
    //   - lastActive: number (optional) - Last active timestamp
    //   - isOnline: bool (optional) - Online status
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email in ["dalinadjib169@gmail.com", "dalinadjib1990@gmail.com", "profjoujou12@gmail.com", "joujouprof12@gmail.com"] && request.auth.token.email_verified == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'points', 'level', 'unlockedLevels', 'levelScores', 'rank']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string && data.displayName.size() < 100 &&
             data.points is number &&
             data.level is number &&
             data.unlockedLevels is list &&
             data.levelScores is map &&
             data.rank in ['worm', 'eagle', 'tiger', 'lion', 'dragon'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        // Allow updating points and rank for others (for challenges)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'rank']))
      );
    }

    match /profiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isAuthenticated() && (
        isOwner(userId) ||
        isAdmin() ||
        // Allow updating points and rank for others (for challenges)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'rank']))
      );
    }

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.challengerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.challengerId || 
        request.auth.uid == resource.data.challengedId ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.challengerId || 
        request.auth.uid == resource.data.challengedId ||
        isAdmin()
      );
    }
  }
}
